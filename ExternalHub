local tabs = {ExternalHub.LoadingFrame, ExternalHub.HomeFrame, ExternalHub.ExclusivesFrame, ExternalHub.RepostedFrame, ExternalHub.CreditsFrame, ExternalHub.LocalLibFrame, ExternalHub.ExclusivesV2Frame, ExternalHub.ADDFrame, ExternalHub.REMOVEFrame, ExternalHub.TerminalFrame};
