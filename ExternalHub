local autocompleteTextbox = ExternalHub.IntellisenseLabel;

-- Returns a command based on the first few letters of the command that the user has inputted
local function getSuggestedCommand()
	for _, commandData in pairs(commands) do
		local aliases = commandData[1];
		for _, alias in pairs(aliases) do
			-- 1 indicates the position of string pattern start. This is so that we only search for similarities from the beginning of the command name
			if string.find(alias, ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text) == 1 then
				return alias;
			end
		end
	end
end

local customIntellisenseList = {};
local function getSuggestedString()
	for i,v in pairs(customIntellisenseList) do
		if string.find(v, ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text) == 1 then
			return v;
		end
	end
end

ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox:GetPropertyChangedSignal("Text"):Connect(function()
	
	local newText = ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text;
	
	-- Check if the user is actually attempting to type a command
	if #newText > 1 and ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox:IsFocused() then
		-- Find commands that match the command the user has typed so far
		autocompleteTextbox.Text = getSuggestedString() or getSuggestedCommand() or "";
	else
		autocompleteTextbox.Text = "";
	end

end)

-- The input for filling the execution textbox with the suggested string provided by the autocomplete/intellisense
game:GetService("UserInputService").InputBegan:Connect(function(input)

	if input.KeyCode == Enum.KeyCode.Tab and #autocompleteTextbox.Text > 0 and ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox:IsFocused() then
		local filledText = autocompleteTextbox.Text;
		game:GetService("RunService").RenderStepped:Wait();	-- Wait for tab space to be rendered
		ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text = filledText;
		autocompleteTextbox.Text = "";
		ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.CursorPosition = #ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text + 1;
	end

end)

ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.FocusLost:Connect(function(enterPressed)
	if enterPressed and #ExternalHub.TerminalFrame.ExecuteFrame.ExecuteTextBox.Text > 0 then
