addCommand({"launch", "launchscript"}, "Launches a script from the library of External Hub (Exclusives V2).", function(scriptNameArg)
	
	local exclusiveV2s = game:GetService("HttpService"):JSONDecode(_G["ExternalHubModules"]["exclusivesv2module"]);
